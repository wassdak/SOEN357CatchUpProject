# Optional override for the post-task survey URL (CRA: REACT_APP_* only).
# If unset, the app uses the team Google Form in src/surveyUrl.js.
#
# Local bundled demo survey only:
# REACT_APP_SURVEY_URL=/survey.html
#
# Custom form:
# REACT_APP_SURVEY_URL=https://docs.google.com/forms/d/e/1FAIpQLSeFgob-_1v3mejFEm0eCu1-aBtQmroTrDvjg3GckG4pGESDAg/viewform?usp=publish-editor

REACT_APP_SURVEY_URL=
